<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <!-- Timestamp -->
                <timestamp>
                    <fieldName>@timestamp</fieldName>
                </timestamp>

                <!-- Versión -->
                <version>
                    <fieldName>@version</fieldName>
                </version>

                <!-- Nivel de log -->
                <logLevel>
                    <fieldName>log.level</fieldName>
                </logLevel>

                <!-- Logger name -->
                <loggerName>
                    <fieldName>logger.name</fieldName>
                </loggerName>

                <!-- Thread name -->
                <threadName>
                    <fieldName>thread.name</fieldName>
                </threadName>

                <!-- Mensaje -->
                <message/>

                <!-- 👇 Aquí está la clave: MDC como objeto anidado -->
                <mdc>
                    <fieldName>http</fieldName>
                    <!-- Esto asegura que los campos del MDC se aniden correctamente -->
                </mdc>

                <!-- Stack trace (opcional) -->
                <stackTrace>
                    <fieldName>stack_trace</fieldName>
                </stackTrace>
            </providers>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <logger name="org.zalando.logbook" level="TRACE" additivity="false">
        <appender-ref ref="JSON_CONSOLE"/>
    </logger>
</configuration>